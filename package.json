    "@fontsource/noto-sans-jp": "5.2.9",
    "date-fns": "4.1.0",
    "react": "19.2.4",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.1.6",
    "@vitejs/plugin-react-swc": "4.2.3",
    "husky": "9.1.7",
    "lint-staged": "16.2.6",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vite-imagetools": "10.0.0"
  }
